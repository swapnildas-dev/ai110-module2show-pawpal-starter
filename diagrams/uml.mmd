classDiagram

class Owner {
    +String name
    +int available_time
    +List~Pet~ pets
    +add_pet(pet)
    +remove_pet(pet_name)
    +get_pets()
}

class Pet {
    +String name
    +String species
    +int age
    +List~Task~ tasks
    +add_task(task)
    +remove_task(task_name)
    +get_tasks()
}

class Task {
    +String name
    +int duration
    +String priority
    +bool completed
    +mark_complete()
    +update_priority(priority)
}

class Scheduler {
    +Owner owner
    +List~Task~ schedule
    +generate_schedule()
    +sort_tasks()
    +display_schedule()
}

Owner "1" --> "*" Pet : owns
Pet "1" --> "*" Task : has
Scheduler --> Owner : manages
Scheduler --> Task : schedules